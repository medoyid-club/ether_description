# Скопіюйте в `.env` у корені проєкту: KEY=value (без лапок, без пробілів навколо =).

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# Числові id чатів через кому (нагадування «спочатку /new» у відстежуваних групах).
TELEGRAM_CHANNEL=

# --- Gemini ---
GEMINI_API_KEY=

# Якщо порожньо — модель обирається автоматично; інакше id без префікса models/ (напр. gemini-2.0-flash).
GEMINI_MODEL=

# Назва каналу в USER_INPUT Gemini (опційно; див. seo_bundle.channel_display_name).
YOUTUBE_CHANNEL_DISPLAY_NAME=

# --- Локальні артефакти ---
# Корінь папок сесії (bundle, відповіді API, ключ після створення ефіру). Якщо порожній — `./output`.
OUTPUT_DIR=

# --- YouTube OAuth + Live ---
# Якщо порожній — береться перший client_secret*.json у корені.
YOUTUBE_CLIENT_SECRET_FILE=
YOUTUBE_TOKEN_FILE=token.json

# Файл з одним або кількома Stream key (по одному рядку, пріоритет зверху вниз).
YOUTUBE_STREAM_KEY_FILE=stream_key.txt

# Категорія відео/ефіру (за замовчуванням розваги ≈ 24). Перевірте для свого регіону при потребі.
YOUTUBE_LIVE_CATEGORY_ID=24
YOUTUBE_LIVE_STREAM_RESOLUTION=1080p
YOUTUBE_LIVE_STREAM_FRAME_RATE=30fps

# Якщо порожній — у коді фіксовано напівприватний режим трансляції (unlisted).
# Або передати явно: private | unlisted | public
YOUTUBE_LIVE_PRIVACY_OVERRIDE=

# --- Опційно / мережа Telegram ---
# TELEGRAM_HTTP_CONNECT_TIMEOUT=30
# TELEGRAM_HTTP_READ_TIMEOUT=45
# TELEGRAM_HTTP_POOL_TIMEOUT=30
# TELEGRAM_HTTP_CONNECTION_POOL_SIZE=1
# TELEGRAM_PROXY=http://127.0.0.1:7890
# TELEGRAM_BOOTSTRAP_RETRIES=25
# TELEGRAM_DEBUG_UPDATES=1

# Stream key для vMix вручну: при потребі задайте YOUTUBE_STREAM_KEY_FILE; за замовчуванням — stream_key.txt у корені.

# Команді /timestamps: залежність youtube-transcript-api (див. requirements.txt), субтитри у відео на YouTube, GEMINI_API_KEY та OAuth token.json як для плейлистів / live.
#
# Запуск на Ubuntu у фоні (systemd / nohup): UBUNTU.md
